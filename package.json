{
  "name": "constella-core-api",
  "version": "1.2.6",
  "description": "Enterprise-grade backend API built with Node.js and TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "dev:sqlite": "cross-env NODE_ENV=development-sqlite nodemon --exec ts-node src/server.ts",
    "build": "tsc && node -e \"require('fs').writeFileSync('dist/package.json', JSON.stringify({type: 'commonjs'}, null, 2))\"",
    "start": "node dist/server.js",
    "start:prod": "cross-env NODE_ENV=production node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check:db": "node scripts/check-db.js",
    "diagnose:yjs": "node scripts/diagnose-yjs.js",
    "reset:db": "node scripts/reset-db.js"
  },
  "keywords": [
    "api",
    "typescript",
    "nodejs",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "bonjour-service": "^1.3.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "level": "^10.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "ws": "^8.19.0",
    "y-websocket": "^3.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bonjour": "^3.5.13",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.28",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.4.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.19.0 || >=22.12.0",
    "npm": ">=9.0.0"
  }
}
